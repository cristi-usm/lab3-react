{
  "name": "starnet-freeview",
  "private": true,
  "version": "0.1.1-rc.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server",
    "build": "tsc -b && vite build",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "preview": "vite preview",
    "prettier": "npm exec prettier src --write",
    "release:patch": "npm version patch -m 'release: cut the %s release' -no-commit-hooks",
    "release:minor": "npm version minor -m 'release: cut the %s release' -no-commit-hooks",
    "release:major": "npm version major -m 'release: cut the %s release' -no-commit-hooks",
    "prerelease": "npm version prerelease --preid=rc -m 'prerelease: cut the %s prerelease' -no-commit-hooks",
    "prerelease:minor": "npm version minor --preid=rc -m 'prerelease: cut the %s prerelease' -no-commit-hooks",
    "prerelease:major": "npm version major --preid=rc -m 'prerelease: cut the %s prerelease' -no-commit-hooks",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.9"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.5",
    "@eslint/js": "^9.21.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@storybook/addon-essentials": "^8.6.4",
    "@storybook/addon-onboarding": "^8.6.4",
    "@storybook/blocks": "^8.6.4",
    "@storybook/experimental-addon-test": "^8.6.4",
    "@storybook/react": "^8.6.4",
    "@storybook/react-vite": "^8.6.4",
    "@storybook/test": "^8.6.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.0.8",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-storybook": "^0.11.4",
    "globals": "^15.15.0",
    "playwright": "^1.51.0",
    "prettier": "3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "storybook": "^8.6.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
